# ============================================
# RAG Demo - Environment Variables
# ============================================
# 复制此文件为 .env 并填入你的密钥
#   cp .env.example .env
# Docker Compose 会自动加载 .env 文件
# ============================================

# --- Chat 模型（OpenAI 兼容 API）---
APP_RAG_CHAT_API_KEY=sk-xxx
APP_RAG_CHAT_BASE_URL=https://api.deepseek.com
APP_RAG_CHAT_MODEL_NAME=deepseek-v4-flash

# --- Embedding 模型 ---
APP_RAG_EMBEDDING_API_KEY=sk-xxx
APP_RAG_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
APP_RAG_EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5

# --- Rerank 模型（默认复用 Embedding 的 key，可单独设置）---
# APP_RAG_RERANK_API_KEY=
APP_RAG_RERANK_BASE_URL=https://api.siliconflow.cn/v1
APP_RAG_RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
# Docker 内使用 mysql 容器名，外部工具连接用 localhost
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/rag_demo?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=${MYSQL_ROOT_PASSWORD}

# --- Redis ---
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# --- 飞书同步（可选）---
APP_FEISHU_APP_ID=
APP_FEISHU_APP_SECRET=
APP_FEISHU_WIKI_ID=
APP_FEISHU_SYNC_ENABLED=false
